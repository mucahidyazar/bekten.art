{
  "name": "bekten.art",
  "version": "3.0.5",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mucahidyazar/bekten.art.git"
  },
  "author": {
    "name": "Mucahid Yazar",
    "email": "mucahidyazar@gmail.com",
    "url": "https://bekten.art"
  },
  "homepage": "https://bekten.art",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "next typegen && tsc --noEmit --incremental false",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:import": "node scripts/import-supabase-export.mjs",
    "instagram:sync": "node scripts/sync-instagram-gallery.mjs",
    "commit": "cz",
    "format": "prettier --write \"**/*.+(js|jsx|json|yml|yaml|css|less|scss|ts|tsx|md|gql|graphql|mdx|vue)\"",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "build:analyze": "ANALYZE=true next build --webpack",
    "up:dev": "docker-compose -f docker-compose.dev.yml up",
    "up:prod": "docker-compose -f docker-compose.prod.yml up"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
